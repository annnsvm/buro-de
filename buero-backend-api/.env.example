DATABASE_URL="postgresql://user:password@localhost:5432/buero_platform_db?schema=public"
NODE_ENV="development"
PORT=3000

# Auth / JWT (заповнюється в тасці по Auth)
JWT_ACCESS_SECRET="your-access-secret-min-32-chars"
JWT_REFRESH_SECRET="your-refresh-secret-min-32-chars"
JWT_ACCESS_EXPIRES_IN="30m"
JWT_REFRESH_EXPIRES_IN="7d"

# Cookie / CORS (див. docs/auth-config.md)
COOKIE_DOMAIN=""
COOKIE_SECURE="false"
CORS_ORIGIN="http://localhost:5173"

# Stripe (купівля курсів, one-time payment)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
# One-time price (Stripe Dashboard: Product → Add price → One time)
STRIPE_PRICE_ID="price_..."
STRIPE_PORTAL_RETURN_URL="http://localhost:5173/settings/billing"

TRIAL_DAYS=7

# Rate limiting (Throttler) — THROTTLE_TTL (секунди), THROTTLE_LIMIT (запитів за період)
THROTTLE_TTL=60
THROTTLE_LIMIT=100